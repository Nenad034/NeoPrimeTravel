# OpenClaw .env — NeoTravel konfiguracija
#
# UPUTSTVO: Kopirajte ovaj fajl u `.env` i popunite vaše vrednosti.
#           NIKAD ne commitujte `.env` sa pravim ključevima na GitHub!
#
# cp .env.example .env

# -----------------------------------------------------------------------------
# Gateway auth + putanje
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=promenite-ovaj-token-na-siguran-string
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace

# -----------------------------------------------------------------------------
# API ključevi modela (postavite bar jedan)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=vas-gemini-api-kljuc-ovde
# OPENROUTER_API_KEY=sk-or-...

# -----------------------------------------------------------------------------
# Kanali (postavite samo one koje koristite)
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# -----------------------------------------------------------------------------
# Alati (opciono)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# FIRECRAWL_API_KEY=...
# ELEVENLABS_API_KEY=...
