// 🌍 NeoTravel Global Hybrid Schema
// Combines Industry Scale Architecture with OlympicHub Operational Excellence

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- CORE PRODUCT DOMAIN (Industry Standards) ---

model Property {
  id                String    @id @default(uuid())
  name              String
  slug              String    @unique
  category          String    // 3*, 4*, 5*, Boutique...
  type              String    // Hotel, Apartment, Villa, Camp
  locationId        String
  address           String
  latitude          Float?
  longitude         Float?
  description       String?   
  amenities         String?   // JSON string in SQLite
  roomTypes         RoomType[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model RoomType {
  id                String    @id @default(uuid())
  propertyId        String
  property          Property  @relation(fields: [propertyId], references: [id])
  name              String    // Standard, Superior, Junior Suite...
  code              String?   // Supplier-specific code mapping
  maxAdults         Int
  maxChildren       Int
  maxOccupancy      Int
  bedConfiguration  String?   // JSON string in SQLite
  roomingRooms      RoomingRoom[]
}

// --- BOOKING & OPERATIONS DOMAIN (Operational Excellence) ---

model Booking {
  id                String    @id @default(uuid())
  cisCode           String    @unique // structured REF - 10000-2026
  jidProdaje        String?   @unique // CIS JID Prodaje
  externalRef       String?   // Provider's ID (Expedia, Solvex...)
  status            String @default("DRAFT")
  customerType      String @default("INDIVIDUAL")
  // Financial & AI Analytics
  totalPrice        Decimal   
  totalNetPrice     Decimal   @default(0)
  totalTaxAmount    Decimal   @default(0)
  totalMarkupAmount Decimal   @default(0)
  totalDiscountAmount Decimal @default(0)
  currency          String    @default("EUR")
  aiTokenUsage      Int       @default(0)    
  aiCostAmount      Decimal   @default(0)   
  
  // Contacts
  bookerName        String
  bookerEmail       String
  bookerPhone       String?
  
  items             BookingItem[]
  passengers        Passenger[]
  payments          Payment[]
  documents         DossierDocument[]
  
  // Operational Intelligence (Your Rooming logic)
  roomingSets       RoomingSet[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  // Intelligence & Monitoring (Inspirisano OlympicHub-AI-Lab)
  activities        DossierActivity[]
  priorityScore     Int       @default(0) // 0-100: Hitnost plaćanja/obrade
  isVccGenerated    Boolean   @default(false)
}

model DossierActivity {
  id                String    @id @default(uuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id])
  type              String    // CREATED, STATUS_CHANGE, PRICE_UPDATE, PASSENGER_MOD, MSG_SENT
  description       String
  userId            String?   // Ko je uradio (Agent ID)
  metadata          String?   // JSON snapshot promene (SQLite string)
  createdAt         DateTime  @default(now())
}

model RoomingSet {
  id                String    @id @default(uuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id])
  label             String?   // "Family Room 1", "Drivers Accommodation"
  rooms             RoomingRoom[]
}

model RoomingRoom {
  id                String    @id @default(uuid())
  roomingSetId      String
  roomingSet        RoomingSet @relation(fields: [roomingSetId], references: [id])
  roomTypeId        String
  roomType          RoomType  @relation(fields: [roomTypeId], references: [id])
  providerRoomId    String?   // Optional: Actual room number or ID from hotel/provider
  passengers        Passenger[]
  status            String?   // Checked-in, Clean, Maintenance
}

model Passenger {
  id                String    @id @default(uuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id])
  roomingRoomId     String?
  roomingRoom       RoomingRoom? @relation(fields: [roomingRoomId], references: [id])
  
  firstName         String
  lastName          String
  type              String @default("ADULT")
  birthDate         DateTime?
  passportNo        String?
  specialRequests   String?   
  isLead            Boolean   @default(false)
}

model BookingItem {
  id                String    @id @default(uuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id])
  type              String    // ACCOMMODATION, TRANSPORT, etc.
  description       String
  unitPrice         Decimal
  quantity          Int       @default(1)
  totalPrice        Decimal
  netPrice          Decimal?  @default(0)
  taxAmount         Decimal?  @default(0)
  markupAmount      Decimal?  @default(0)
  discountAmount    Decimal?  @default(0)
  currency          String
  
  // Monitoring (Sekcija 1.1 Supplier Obligations)
  startDate         DateTime? // Datum početka usluge
  endDate           DateTime? // Datum završetka usluge
  supplierDeadline  DateTime? // Datum do kog se mora platiti dobavljaču
  cancelDeadline    DateTime? // Datum do kog je besplatno otkazivanje
  externalStatus    String?   // Status kod dobavljača (npr. "Confirmed", "On Request")
}

model CommercialRule {
  id                String    @id @default(uuid())
  name              String
  type              String    // MARKUP, COMMISSION, DISCOUNT, FEE
  targetType        String    // GLOBAL, PRODUCT_TYPE, SUPPLIER, DESTINATION
  targetValue       String?   // e.g. "HOTEL", "Expedia", "EG"
  calculationType   String    // PERCENT, FIXED, STEPPED
  value             Decimal
  priority          Int       @default(0)
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
}

model BundleRule {
  id                String    @id @default(uuid())
  name              String
  requiredItems     String    // Comma separated types, e.g. "HOTEL,FLIGHT"
  discountType      String    // PERCENT, FIXED
  discountValue     Decimal
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())
}

model MasterHotel {
  id                String    @id @default(uuid())
  name              String
  destinationCode   String
  stars             Int
  latitude          Float?
  longitude         Float?
  mappings          HotelMapping[]
  createdAt         DateTime  @default(now())
}

model HotelMapping {
  id                String      @id @default(uuid())
  masterHotelId     String
  masterHotel       MasterHotel @relation(fields: [masterHotelId], references: [id])
  supplierId        String      // e.g. "EXPEDIA", "WEBBEDS"
  supplierHotelCode String      // Šifra hotela kod tog dobavljača
  lastSync          DateTime    @default(now())

  @@unique([supplierId, supplierHotelCode])
}

model RoomTypeMapping {
  id                String    @id @default(uuid())
  masterRoomCode    String    // npr. "double_deluxe"
  supplierId        String
  supplierRoomName  String    // npr. "DLX DBL"
  supplierRoomCode  String?
}

model BoardMapping {
  id                String    @id @default(uuid())
  masterBoardCode   String    // npr. "ALL_INCLUSIVE"
  supplierId        String
  supplierBoardName String    // npr. "AI", "All Incl"
}

model Payment {
  id                String    @id @default(uuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id])
  amount            Decimal   
  currency          String
  method            String    // Cash, Card, Bank, VCC
  status            String @default("PENDING")
  
  // Fiscal/Regulatory Link (Adaptable for any country)
  fiscalId          String?   // PFR number, SEF ID, etc.
  localTaxAmount    Decimal?  
  exchangeRate      Decimal?  
  
  processedAt       DateTime?
}

model DossierDocument {
  id                String    @id @default(uuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id])
  type              String    // PROFORMA, INVOICE, VOUCHER, RECEIPT, CONTRACT
  documentNo        String    @unique // npr. PF-2026-001
  content           String?   // Može biti HTML, JSON ili putanja do fajla
  fileUrl           String?   // Link ka generisanom PDF-u
  issuedAt          DateTime  @default(now())
  issuedBy          String?   // Agent ID
  isFinal           Boolean   @default(false)
}

model CisTrip {
  id                String    @id @default(uuid())
  bookingId         String
  tripReference     String
  submissionStatus  String
  createdAt         DateTime  @default(now())
}

model FiscalReceipt {
  id                String    @id @default(uuid())
  bookingId         String
  paymentId         String
  receiptType       String
  amount            Decimal
  currency          String
  status            String
  fiscalReference   String
  qrCodeData        String?
  createdAt         DateTime  @default(now())
}
